<mujoco model="teleop_station_scene">
  <compiler angle="radian" meshdir="assets"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <include file="assets/franka_emika_panda/panda.xml"/>
  ###
  <visual>
    <headlight ambient='0.35 0.35 0.35' diffuse='0.6 0.6 0.6' specular='0.1 0.1 0.1'/>
    <rgba haze='0.45 0.48 0.52 1'/>
    <quality shadowsize='1024'/>
    <map znear='0.01' zfar='50'/>
  </visual>
  ###          
  <asset>
    <!-- Simple XML colors -->
    <material name="station_mat" rgba="0.72 0.72 0.70 1"/>
    <material name="floor_mat" rgba="0.45 0.45 0.45 1"/>

    <!-- Use the cleaned OBJ file -->
    <mesh name="teleop_station_mesh" file="meshes/teleop_clean2.obj"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <!-- diffuse="0.9 0.9 0.9" -->
    <light name="top_light"
           pos="0 0 4"
           diffuse="0.45 0.45 0.45"
           specular="0.2 0.2 0.2"/>

    <light name="front_light"
           pos="2 -2 2"
           diffuse="0.25 0.25 0.25"/>

    <!-- Camera view -->
    <camera name="overview"
            pos="2.6 -2.8 1.8"
            xyaxes="0.73 0.68 0 -0.35 0.38 0.86"/>

    <!-- MuJoCo floor -->
    <geom name="floor"
          type="plane"
          pos="1 1 0"
          size="5 5 0.1"
          material="floor_mat"/>

    
    <body name="teleop_station" pos="0 0 0" euler="1.5708 0 0">
      <geom name="teleop_station_visual"
            type="mesh"
            mesh="teleop_station_mesh"
            material="station_mat"
            contype="0"
            conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>