<mujoco model="panda_teleop_station_color">

  <compiler angle="radian"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <!-- Panda robot -->
  <include file="assets/franka_emika_panda/panda.xml"/>

  <visual>
    <headlight ambient="0.45 0.45 0.45"
               diffuse="0.75 0.75 0.75"
               specular="0.15 0.15 0.15"/>
    <rgba haze="0.70 0.82 0.96 1"/>
    <quality shadowsize="2048"/>
    <map znear="0.01" zfar="50"/>
  </visual>

  <statistic center="0 0 0.8" extent="3"/>

  <asset>
    
    <texture name="skybox" type="skybox" builtin="gradient"
             rgb1="0.55 0.75 0.95"
             rgb2="0.92 0.97 1.00"
             width="512" height="512"/>

    <material name="floor_mat"   rgba="0.55 0.58 0.62 1"/>
    <material name="table_mat"   rgba="0.88 0.88 0.84 1"/>
    <material name="mount_mat"   rgba="0.68 0.30 0.8 1"/>
    <material name="pc_mat"      rgba="0.05 0.05 0.06 1"/>

    <material name="blind_mat"   rgba="0.95 0.83 0.22 1"/>
    <material name="camera_mat"  rgba="0.18 0.18 0.20 1"/>
    <material name="element_mat" rgba="0.55 0.32 0.14 1"/>

    <mesh name="tables_mesh"         file="assets/meshes/tables.obj"/>
    <mesh name="robo_mount_mesh"     file="assets/meshes/robo_mount.obj"/>
    <mesh name="pc_spacemouse_mesh"  file="assets/meshes/pc_spacemouse.obj"/>
    <mesh name="blinds_mesh"         file="assets/meshes/blinds.obj"/>
    <mesh name="camera_stands_mesh"  file="assets/meshes/camera_stands.obj"/>
    <mesh name="elements_mesh"       file="assets/meshes/elements.obj"/>
  </asset>

  <worldbody>
    <!-- lighting -->
    <light name="top_light"
           pos="0 0 3.0"
           dir="0 0 -1"
           diffuse="1 1 1"
           specular="0.2 0.2 0.2"
           castshadow="true"/>

    <light name="fill_light"
           pos="1.8 -1.5 2.2"
           dir="-0.4 0.2 -1"
           diffuse="0.5 0.5 0.5"
           specular="0.05 0.05 0.05"
           castshadow="false"/>

    <!-- overview camera -->
    <camera name="overview"
            pos="0.20 -2.40 1.80"
            xyaxes="1 0 0 0 0.6 0.8"/>

    <!-- floor -->
    <geom name="floor"
          type="plane"
          size="5 5 0.1"
          material="floor_mat"/>

    <!-- teleoperation station scene -->
    <body name="teleop_station" pos="0 0 0" euler="1.5708 0 0">

      <geom name="tables_geom"
            type="mesh"
            mesh="tables_mesh"
            material="table_mat"/>

      <geom name="robo_mount_geom"
            type="mesh"
            mesh="robo_mount_mesh"
            material="mount_mat"/>

      <geom name="pc_spacemouse_geom"
            type="mesh"
            mesh="pc_spacemouse_mesh"
            material="pc_mat"/>

      <geom name="blinds_geom"
            type="mesh"
            mesh="blinds_mesh"
            material="blind_mat"/>

      <geom name="camera_stands_geom"
            type="mesh"
            mesh="camera_stands_mesh"
            material="camera_mat"/>

      <geom name="elements_geom"
            type="mesh"
            mesh="elements_mesh"
            material="element_mat"/>
    </body>
  </worldbody>

</mujoco>