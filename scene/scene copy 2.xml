<mujoco model="teleop_station_scene">
  <compiler angle="radian" meshdir="assets"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <asset>
    <!-- Simple XML colors -->
    <material name="station_mat" rgba="0.72 0.72 0.70 1"/>
    <material name="floor_mat" rgba="0.28 0.28 0.28 1"/>

    <!-- Use the cleaned OBJ file -->
    <mesh name="teleop_station_mesh" file="meshes/teleop_station_clean.obj"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <light name="top_light"
           pos="0 0 4"
           diffuse="0.9 0.9 0.9"
           specular="0.2 0.2 0.2"/>

    <light name="front_light"
           pos="2 -2 2"
           diffuse="0.45 0.45 0.45"/>

    <!-- Camera view -->
    <camera name="overview"
            pos="2.6 -2.8 1.8"
            xyaxes="0.73 0.68 0 -0.35 0.38 0.86"/>

    <!-- MuJoCo floor -->
    <geom name="floor"
          type="plane"
          pos="1 1 0"
          size="5 5 0.1"
          material="floor_mat"/>

    
    <body name="teleop_station" pos="0 0 0" euler="1.5708 0 0">
      <geom name="teleop_station_visual"
            type="mesh"
            mesh="teleop_station_mesh"
            material="station_mat"
            contype="0"
            conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>